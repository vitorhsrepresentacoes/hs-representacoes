GHL_LOCATION_ID=id-da-location
GHL_PIPELINE_ID=id-do-pipeline
GHL_STAGE_NEW_ID=id-do-estagio-novo-lead-site
GHL_STAGE_QUALIFIED_ID=id-do-estagio-qualificado-ia
